<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!--
        Base window theme — needed by the Android OS to style the app window
        before Jetpack Compose takes over.
    -->
    <style name="Theme.JobAlerts" parent="android:Theme.Material.Light.NoActionBar" />

    <!--
        Splash screen theme (Android 12+ SplashScreen API).
        The launcher icon shows briefly during cold start, then transitions to
        Theme.JobAlerts once Compose is ready.
    -->
    <style name="Theme.JobAlerts.Splash" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">#FFFFFF</item>
        <item name="windowSplashScreenAnimatedIcon">@drawable/ic_launcher_foreground</item>
        <item name="postSplashScreenTheme">@style/Theme.JobAlerts</item>
    </style>
</resources>
